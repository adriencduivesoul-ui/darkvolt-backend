    "postinstall": "esbuild index.ts --platform=node --packages=external --bundle --format=esm --outdir=dist"
  },
  "dependencies": {
    "express": "^4.21.2",
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "@types/express": "4.17.21",
    "@types/node": "^24.7.0",
    "esbuild": "^0.25.0",
    "tsx": "^4.19.1",
    "typescript": "5.6.3"
  }
}
